State Management
Use a Pinia store:
typescript// stores/integrations.ts
import { defineStore } from 'pinia'

interface Connection {
  id: string
  provider: string        // 'jira', 'slack', etc.
  category: 'task' | 'messaging' | 'calendar'
  status: 'connected' | 'disconnected'
  workspace?: string      // 'acme-corp.atlassian.net'
  connectedBy?: string
  connectedAt?: string
  lastSyncAt?: string
  settings?: {
    projectMode: 'all' | 'selected'
    selectedProjects: string[]
    assignmentMode: 'mirror' | 'everyone'
    channel?: string
    notifications?: {
      dailySummary: boolean
      overtimeAlerts: boolean
      trackingReminders: boolean
      timeOff: boolean
    }
  }
}

export const useIntegrationsStore = defineStore('integrations', {
  state: () => ({
    connections: [] as Connection[],
    loading: false,
    error: null as string | null,
  }),
  
  getters: {
    connectedProviders: (state) => state.connections.filter(c => c.status === 'connected'),
    activeCount: (state) => state.connections.filter(c => c.status === 'connected').length,
    getByProvider: (state) => (provider: string) => state.connections.find(c => c.provider === provider),
    taskConnections: (state) => state.connections.filter(c => c.category === 'task' && c.status === 'connected'),
    messagingConnections: (state) => state.connections.filter(c => c.category === 'messaging' && c.status === 'connected'),
  },

  actions: {
    async fetchConnections() { /* GET /integrations */ },
    async connect(provider: string) { /* POST /integrations/connect */ },
    async disconnect(id: string) { /* DELETE /integrations/{id} */ },
    async updateSettings(id: string, settings: object) { /* PUT /integrations/{id}/settings */ },
    async forceSync(id: string) { /* POST /integrations/{id}/sync */ },
    async fetchUserMappings(id: string) { /* GET /integrations/{id}/user-mapping */ },
    async updateUserMapping(id: string, mappingId: string, userId: string) { /* PUT */ },
  }
})

